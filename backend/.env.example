# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection
# Local MongoDB: mongodb://localhost:27017/mobile-shop
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mobile-shop?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mobile-shop

# JWT Secret (Change this to a secure random string in production)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=30d

# Client URL (React Frontend)
CLIENT_URL=http://localhost:3000
