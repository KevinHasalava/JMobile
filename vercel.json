{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!static|favicon\\.ico|manifest\\.json|robots\\.txt|logo.*\\.png).*)",
      "destination": "/index.html"
    }
  ]
}
